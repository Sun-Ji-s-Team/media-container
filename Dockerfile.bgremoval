FROM --platform=linux/amd64 node:22-slim

WORKDIR /app

COPY package.bgremoval.json package.json
COPY package-lock.bgremoval.json package-lock.json
RUN npm ci --omit=dev && npm cache clean --force

COPY dist/bgremoval-server.js dist/bgremoval-server.js

ENV PORT=8080
EXPOSE 8080

CMD ["node", "dist/bgremoval-server.js"]
